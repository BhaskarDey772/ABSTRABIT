# Copy to .env and fill in real values. Never commit .env.

# --- Database (Supabase Postgres, via Prisma) ---
# DATABASE_URL: pooled connection (pgbouncer, port 6543) — used by the app at runtime.
# DIRECT_URL: unpooled connection (port 5432) — used by Prisma for migrations.
DATABASE_URL=
DIRECT_URL=

# --- Supabase (DB + Auth for the admin dashboard) ---
# New key system (Settings -> API Keys): publishable = client-side, secret = server-side.
# Not the legacy anon/service_role JWTs — those still work but Supabase now flags them legacy.
# NEXT_PUBLIC_* are the same publishable values, just also exposed to the browser
# bundle (Next.js only inlines env vars prefixed NEXT_PUBLIC_ into client code) —
# needed because the "Sign in with Discord" button runs client-side.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- Discord application (Developer Portal) ---
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=
DISCORD_DEV_GUILD_ID=

# --- Mirror channel (pick one, wire both if going for the multi-target stretch) ---
SLACK_WEBHOOK_URL=
DISCORD_MIRROR_WEBHOOK_URL=

# --- NVIDIA NIM (each key is scoped to the model it was issued for) ---
NVIDIA_API_KEY_PRIMARY=
NVIDIA_MODEL_PRIMARY=nvidia/llama-3.3-nemotron-super-49b-v1.5
NVIDIA_API_KEY_FALLBACK=
NVIDIA_MODEL_FALLBACK=nvidia/llama-3.1-nemotron-nano-8b-v1

# --- Cron (daily retry sweep for failed mirrors/AI tagging, see vercel.json) ---
# Any random string; Vercel auto-sends it as "Authorization: Bearer <value>" to its own cron hits.
CRON_SECRET=
